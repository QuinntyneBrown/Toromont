{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Authentication": {
    "UseDevMode": true
  },
  "DevNotificationDelivery": {
    "Enabled": true,
    "UseSmtp": true,
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "EmailDropFolder": "artifacts/dev-emails",
    "EnableSmsConsoleSink": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug"
    }
  }
}
