@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Equipment Management - System Context

Person(fleetMgr, "Fleet Manager", "Manages equipment fleet,\nregisters and updates assets")
Person(operator, "Operator", "Views equipment details\nand status (read-only)")
Person(admin, "Admin", "Full CRUD, manages\nlegacy imports")
Person(technician, "Technician", "Views equipment specs\nand service history")

System(fleetHub, "Ironvale Fleet Hub", "Equipment fleet management\nand service portal\n(.NET 8+ / Angular / SQL Server 2022)")

System_Ext(entraId, "Microsoft Entra ID", "Identity provider\n(OAuth2/OIDC)")
System_Ext(legacyFeed, "Legacy XML Feed", "Existing equipment\nmanagement systems\nexporting XML data")
System_Ext(catTelematics, "CAT Product Link", "Equipment telemetry\ndata source")

Rel(fleetMgr, fleetHub, "Registers, updates,\nand views equipment", "HTTPS")
Rel(operator, fleetHub, "Views equipment\nlist and details", "HTTPS")
Rel(admin, fleetHub, "Full CRUD,\nimports legacy data", "HTTPS")
Rel(technician, fleetHub, "Views equipment\nspecs and history", "HTTPS")

Rel(fleetHub, entraId, "Authenticates users", "OAuth2/OIDC")
Rel(legacyFeed, fleetHub, "Exports equipment data", "XML")
Rel(catTelematics, fleetHub, "Sends telemetry\nfor equipment", "HTTPS/JSON")

@enduml
