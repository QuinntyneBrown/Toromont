@startuml c4_component
!theme plain
!pragma layout smetana
left to right direction
skinparam shadowing false
skinparam defaultFontSize 11
skinparam rectangle {
  RoundCorner 10
  StereotypeFontSize 10
}

title Tenant Query Filter Hardening - C4 Component

skinparam rectangle<<backend>> {
  BackgroundColor #438DD5
  FontColor white
  BorderColor #2E6DA4
}
skinparam rectangle<<service>> {
  BackgroundColor #2E86C1
  FontColor white
  BorderColor #1F618D
}

rectangle "TenantContextMiddleware\n\nSets current org/user" <<service>> as mw
rectangle "FleetHubDbContext\n\nCurrentOrganizationId\nTenantResolved" <<backend>> as ctx
rectangle "Global Query Filters\n\nAlways registered\nFail closed" <<service>> as filters
rectangle "Feature Handlers\n\nUse filtered DbSets" <<backend>> as handlers
rectangle "Bootstrap Queries\n\nUse IgnoreQueryFilters" <<service>> as bootstrap
database "SQL Server" as db

mw --> ctx : scoped tenant state
ctx --> filters : evaluate per request
handlers --> ctx : tenant-scoped queries
filters --> db : filtered SQL
bootstrap --> ctx : explicit bypass
bootstrap --> db : unfiltered SQL

@enduml
