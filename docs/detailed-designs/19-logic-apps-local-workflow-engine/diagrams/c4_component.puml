@startuml c4_component
!theme plain
!pragma layout smetana
left to right direction
skinparam shadowing false
skinparam defaultFontSize 11
skinparam rectangle {
  RoundCorner 10
  StereotypeFontSize 10
}

title Logic Apps Local Workflow Engine - C4 Component

skinparam rectangle<<backend>> {
  BackgroundColor #438DD5
  FontColor white
  BorderColor #2E6DA4
}
skinparam rectangle<<service>> {
  BackgroundColor #2E86C1
  FontColor white
  BorderColor #1F618D
}

rectangle "ASP.NET Core API\n(Development Host)" <<backend>> as api
rectangle "LocalWorkflowEngineHostedService\nScheduler + execution loop" <<service>> as host
rectangle "ServiceReminderWorkflow\n7d / 3d / 1d" <<service>> as reminder
rectangle "WorkOrderEscalationWorkflow\n48h escalation" <<service>> as escalation
rectangle "PartsOrderStatusWorkflow\nLocal fulfillment events" <<service>> as parts
rectangle "NotificationDispatchService" <<service>> as notif
database "SQL Server / InMemory DB" as db

api --> host : starts in Development
host --> reminder : executes
host --> escalation : executes
host --> parts : executes
reminder --> db : query candidates
escalation --> db : update priority
parts --> db : update order status
reminder --> notif : create reminders
escalation --> notif : create escalations
parts --> notif : create updates

@enduml
