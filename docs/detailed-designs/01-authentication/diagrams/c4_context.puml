@startuml c4_context
!theme plain
!include <C4/C4_Context>

title Toromont Fleet Hub - System Context

Person(fleetMgr, "Fleet Manager", "Manages equipment fleet,\nwork orders, parts orders")
Person(technician, "Technician", "Updates work order status,\nviews equipment telemetry")
Person(operator, "Operator", "Views equipment and\ntelemetry (read-only)")
Person(admin, "Admin", "Manages users, roles,\norganization settings")

System(fleetHub, "Toromont Fleet Hub", "Equipment Fleet Management\n& Service Portal")

System_Ext(entraId, "Microsoft Entra ID", "Identity provider\n(OAuth2/OIDC)")
System_Ext(catTelematics, "CAT Product Link", "Equipment telemetry\ndata source")
System_Ext(emailSvc, "Email Service", "SendGrid / SMTP\nemail delivery")
System_Ext(smsSvc, "SMS Gateway", "Twilio / Azure\nSMS delivery")
System_Ext(legacySys, "Legacy Systems", "XML equipment\ndata feeds")

Rel(fleetMgr, fleetHub, "Uses", "HTTPS")
Rel(technician, fleetHub, "Uses", "HTTPS")
Rel(operator, fleetHub, "Uses", "HTTPS")
Rel(admin, fleetHub, "Uses", "HTTPS")

Rel(fleetHub, entraId, "Authenticates via", "OAuth2/OIDC")
Rel(catTelematics, fleetHub, "Sends telemetry", "HTTPS/JSON")
Rel(fleetHub, emailSvc, "Sends emails", "SMTP/API")
Rel(fleetHub, smsSvc, "Sends SMS", "API")
Rel(legacySys, fleetHub, "Exports equipment data", "XML")

@enduml
